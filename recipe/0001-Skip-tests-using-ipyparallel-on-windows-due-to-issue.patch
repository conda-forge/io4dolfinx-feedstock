From: Henrik Finsberg <henrikfinsberg@hotmail.com>
Date: Wed, 13 May 2026 10:28:46 +0200
Subject: [PATCH] Skip tests using ipyparallel on windows due to issue with
 file locks on windows

---
 tests/conftest.py | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/tests/conftest.py b/tests/conftest.py
index c3d6a82..15a6a4a 100644
--- a/tests/conftest.py
+++ b/tests/conftest.py
@@ -1,3 +1,4 @@
+import sys
 import typing
 from collections import ChainMap
 
@@ -39,6 +40,10 @@ def backend(request):
 
 @pytest.fixture(scope="module")
 def cluster():
+
+    if sys.platform.startswith("win"):
+        pytest.skip("ipyparallel background engines cause file locking issues on Windows")
+
     cluster = ipp.Cluster(engines="mpi", n=2)
     rc = cluster.start_and_connect_sync()
     rc.wait_for_engines(n=2)
